{
  "name": "jmr-visuals-portfolio",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "npx playwright test",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:a11y": "npx playwright test tests/accessibility.spec.ts",
    "test:crossbrowser": "npx playwright test tests/cross-browser.spec.ts",
    "test:lighthouse": "npm run build && node tests/lighthouse-audit.mjs",
    "test:all": "npm run build && npx playwright test && node tests/lighthouse-audit.mjs"
  },
  "dependencies": {
    "astro": "^7.0.6",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "lighthouse": "^13.4.0"
  }
}
