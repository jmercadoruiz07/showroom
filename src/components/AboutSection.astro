---
/*
|-------------------------------------------------------------------------------
| AboutSection — JMR Visuals Portfolio
|-------------------------------------------------------------------------------
|
| Two-column asymmetric layout (30% portrait / 70% bio text).
| Portrait image with no frame, bleeds to edge on one side.
| Bio in Body font, pull quotes in Display italic. Contact CTA at bottom.
|
*/
interface Props {
  name?: string;
  title?: string;
  bio?: string;
  portrait?: string;
  portraitAlt?: string;
  pullQuote?: string;
  email?: string;
}

const {
  name = 'JMR Visuals',
  title = 'Designer & 3D Artist',
  bio = 'A multidisciplinary designer specializing in print, 3D, and motion design. Based in Barcelona, working globally.',
  portrait = '/images/about-portrait.jpg',
  portraitAlt = 'Portrait of JMR Visuals',
  pullQuote = 'Design is not just what it looks like. Design is how it works.',
  email = 'hello@jmrvisuals.com',
} = Astro.props;
---

<section class="about-section" aria-labelledby="about-title">
  <div class="about-grid grid-asymmetric-30-70">
    <div class="about-portrait" aria-hidden="true">
      <img
        src={portrait}
        alt={portraitAlt}
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="about-content">
      <header class="about-header">
        <span class="about-label text-mono">ABOUT</span>
        <h2 id="about-title" class="about-title text-display">{name}</h2>
        <p class="about-role text-body">{title}</p>
      </header>

      <div class="about-bio text-body">
        {bio.split('\n\n').map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>

      {pullQuote && (
        <blockquote class="pull-quote text-display" cite="https://www.artstation.com/jmr_visuals">
          <p>&ldquo;{pullQuote}&rdquo;</p>
        </blockquote>
      )}

      <footer class="about-contact">
        <a href={`mailto:${email}`} class="contact-link text-mono">
          {email}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </footer>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: var(--space-3xl) var(--space-xl);
    padding-left: calc(var(--space-xl) * 2);
  }

  .about-grid {
    max-width: var(--max-width-full);
    margin: 0 auto;
    gap: var(--space-3xl);
    align-items: start;
  }

  .about-portrait {
    position: relative;
  }

  .about-portrait img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  .about-header {
    margin-bottom: var(--space-xl);
  }

  .about-label {
    display: inline-block;
    font-size: var(--type-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-oxide-muted);
    margin-bottom: var(--space-sm);
  }

  .about-title {
    font-size: var(--type-2xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--line-height-tight);
    margin: 0 0 var(--space-sm);
  }

  .about-role {
    font-size: var(--type-md);
    color: var(--color-soot);
    margin: 0;
    max-width: none;
  }

  .about-bio {
    font-size: var(--type-base);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-2xl);
  }

  .about-bio p {
    margin-bottom: var(--space-md);
    max-width: none;
  }

  .pull-quote {
    margin: var(--space-2xl) 0;
    padding: 0;
    border: none;
    font-size: var(--type-xl);
    font-weight: var(--font-weight-bold);
    font-style: italic;
    letter-spacing: var(--tracking-tight);
    line-height: var(--line-height-snug);
    color: var(--color-ink);
    position: relative;
    padding-left: var(--space-xl);
  }

  .pull-quote::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--color-oxide);
  }

  .pull-quote p {
    margin: 0;
    max-width: none;
  }

  .about-contact {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-stone);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--type-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-ink);
    transition: color var(--duration-fast) var(--ease-quick),
                gap var(--duration-fast) var(--ease-quick);
  }

  .contact-link:hover {
    color: var(--color-oxide);
    gap: var(--space-md);
  }

  [data-theme="dark"] .contact-link {
    color: var(--color-deep-text);
  }

  [data-theme="dark"] .contact-link:hover {
    color: var(--color-oxide);
  }

  [data-theme="dark"] .pull-quote {
    color: var(--color-deep-text);
  }

  @media (max-width: 768px) {
    .about-section {
      padding: var(--space-2xl) var(--space-md);
      padding-left: var(--space-md);
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .about-portrait {
      max-width: 60%;
      margin: 0 auto;
    }

    .about-title {
      font-size: var(--type-xl);
    }

    .pull-quote {
      font-size: var(--type-lg);
    }
  }
</style>