---
/*
|-------------------------------------------------------------------------------
| ContactBlock — JMR Visuals Portfolio
|-------------------------------------------------------------------------------
|
| Minimal contact info: email link + custom SVG social icons.
| Inline layout, footer-adjacent. Icon color transitions to --color-oxide on hover.
|
*/
interface Props {
  email?: string;
}

const { email = 'hello@jmrvisuals.com' } = Astro.props;
---

<section class="contact-block" aria-labelledby="contact-title">
  <h2 id="contact-title" class="contact-title text-display">Get in Touch</h2>
  <p class="contact-text text-body">Have a project in mind? Let's talk about it.</p>

  <div class="contact-links">
    <a href={`mailto:${email}`} class="contact-email text-mono">
      {email}
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </a>
  </div>

  <div class="contact-social" aria-label="Social links">
    <a href="https://www.artstation.com/jmr_visuals" class="social-link" aria-label="ArtStation" target="_blank" rel="noopener noreferrer">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M0 17.723l2.027 3.505h.001a2.424 2.424 0 0 0 2.164 1.333h13.457l-2.792-4.838H0zm24-.027L21.973 13.5H8.352l2.028 3.505h13.457zM15.495 9.662l-2.028-3.505h-7.3L8.135 9.662h7.36zm-5.328-5.85L8.136 7.316l-2.028-3.505L0 17.73l2.027 3.505h17.946l2.027-3.505-6.833-11.72z"/>
      </svg>
    </a>
    <a href="https://www.instagram.com" class="social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
      </svg>
    </a>
    <a href="https://www.linkedin.com" class="social-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .contact-block {
    padding: var(--space-3xl) var(--space-xl);
    padding-left: calc(var(--space-xl) * 2);
    border-top: 1px solid var(--color-stone);
  }

  .contact-title {
    font-size: var(--type-2xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-md);
  }

  .contact-text {
    font-size: var(--type-md);
    color: var(--color-soot);
    margin: 0 0 var(--space-xl);
    max-width: 40ch;
  }

  .contact-links {
    margin-bottom: var(--space-xl);
  }

  .contact-email {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--type-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-ink);
    transition: color var(--duration-fast) var(--ease-quick),
                gap var(--duration-fast) var(--ease-quick);
  }

  .contact-email:hover {
    color: var(--color-oxide);
    gap: var(--space-md);
  }

  .contact-social {
    display: flex;
    gap: var(--space-md);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-ink);
    opacity: 0.6;
    transition: opacity var(--duration-fast) var(--ease-quick),
                color var(--duration-fast) var(--ease-quick);
  }

  .social-link:hover {
    opacity: 1;
    color: var(--color-oxide);
  }

  [data-theme="dark"] .contact-email {
    color: var(--color-deep-text);
  }

  [data-theme="dark"] .contact-email:hover {
    color: var(--color-oxide);
  }

  [data-theme="dark"] .social-link {
    color: var(--color-deep-text);
  }

  [data-theme="dark"] .social-link:hover {
    color: var(--color-oxide);
  }

  @media (max-width: 768px) {
    .contact-block {
      padding: var(--space-2xl) var(--space-md);
    }
  }
</style>
