---
/*
|-------------------------------------------------------------------------------
| BaseLayout — JMR Visuals Portfolio
|-------------------------------------------------------------------------------
|
| Root HTML shell with <head>, font preloads, global styles, and slot for page content.
| All pages should use this layout.
|
*/
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title,
  description = 'Portfolio of JMR Visuals — Print, 3D, and Motion Design',
  ogImage = '/og-default.jpg',
  canonicalURL,
} = Astro.props;

const canonical = canonicalURL || Astro.url.href;
import { ClientRouter } from 'astro:transitions';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | JMR Visuals</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.url).href} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.url).href} />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Font Preloads -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/PlayfairDisplay-Bold.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/InstrumentSans-Regular.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/JetBrainsMono-Regular.woff2" />

    <!-- Critical CSS Inlined -->
    <style>
      {`
        /* Critical path CSS - tokens, reset, fonts, and layout basics */
        :root {
          --color-ink: oklch(0.15 0.01 60);
          --color-soot: oklch(0.35 0.01 60);
          --color-stone: oklch(0.70 0.01 60);
          --color-bone: oklch(0.96 0.005 80);
          --color-paper: oklch(0.93 0.008 75);
          --color-oxide: oklch(0.55 0.14 45);
          --color-oxide-muted: oklch(0.48 0.10 45);
          --color-deep: oklch(0.12 0.015 60);
          --color-deep-text: oklch(0.88 0.008 75);

          --font-display: "Playfair Display", Georgia, serif;
          --font-body: "Instrument Sans", "Trebuchet MS", sans-serif;
          --font-weight-regular: 400;
          --font-weight-bold: 700;
          --tracking-tight: -0.02em;

          --type-base: clamp(1rem, 0.92rem + 0.35vw, 1.125rem);

          --line-height-tight: 1.15;
          --line-height-normal: 1.6;
        }
        [data-theme="dark"] {
          --color-bone: var(--color-deep);
          --color-paper: oklch(0.18 0.015 60);
          --color-ink: var(--color-deep-text);
          --color-soot: oklch(0.65 0.01 75);
          --color-stone: oklch(0.35 0.01 60);
        }
        *, *::before, *::after { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body { margin: 0; min-height: 100vh; font-family: var(--font-body); font-size: var(--type-base); line-height: var(--line-height-normal); color: var(--color-ink); background: var(--color-bone); -webkit-font-smoothing: antialiased; }
        h1, h2, h3, h4, h5, h6 { margin: 0; font-family: var(--font-display); font-weight: var(--font-weight-bold); line-height: var(--line-height-tight); color: var(--color-ink); }
        img, picture, video { display: block; max-width: 100%; height: auto; }
        a { color: inherit; text-decoration: none; }
        .skip-link { position: absolute; top: -100%; left: 1rem; padding: 0.5rem 1rem; background: var(--color-ink); color: var(--color-bone); z-index: 600; }
        .skip-link:focus { top: 1rem; }
      `}
    </style>

    <!-- Full Stylesheets -->
    <link rel="stylesheet" href="/styles/fonts.css" />
    <link rel="stylesheet" href="/styles/tokens.css" />
    <link rel="stylesheet" href="/styles/reset.css" />
    <link rel="stylesheet" href="/styles/global.css" />

    <!-- Client-side Router (View Transitions) -->
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <SiteHeader />
    <slot />
    <SiteFooter />

    <script is:inline src="/scripts/theme-toggle.js"></script>
    <script is:inline src="/scripts/back-to-top.js"></script>
    <script is:inline src="/scripts/scroll-reveal.js"></script>
  </body>
</html>