---
/*
|-------------------------------------------------------------------------------
| ProjectLayout — JMR Visuals Portfolio
|-------------------------------------------------------------------------------
|
| Layout wrapper for project detail pages.
| Handles view transitions for hero image morphing.
|
*/
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalURL={Astro.url.href}
>
  <slot />
</BaseLayout>