---
/*
|-------------------------------------------------------------------------------
| Project Detail Page — JMR Visuals Portfolio
|-------------------------------------------------------------------------------
|
| Split-screen layout (60/40 or 70/30) alternating per project.
| Media pane: scrollable image gallery or embedded 3D viewer.
| Text pane: title (Display), description (Body), metadata (Mono).
| Navigation: "← All Projects" text link.
|
*/
import { getCollection } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import ModelViewer from '../../components/ModelViewer.astro';
import MediaViewer from '../../components/MediaViewer.astro';

// Generate static paths for all projects
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, date, category, tags, images, model, modelPoster, tools, description, featured } = project.data;

// Alternate layout based on order or slug
const isEven = (project.data.order || 0) % 2 === 0;
const mediaWidth = isEven ? '60%' : '40%';
const textWidth = isEven ? '40%' : '60%';
const mediaFirst = isEven;

const categoryLabels: Record<string, string> = {
  print: 'PRINT',
  '3d': '3D',
  motion: 'MOTION',
};

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};
---

<ProjectLayout
  title={title}
  description={description}
  ogImage={(images?.[0] || modelPoster)?.src}
>
  <main id="main-content">
  <article class="project-detail">
    <header class="project-header">
      <a href="/projects" class="back-link text-mono">
        ← All Projects
      </a>

      <div class="project-meta">
        <span class="project-category text-mono">{categoryLabels[category] || category.toUpperCase()}</span>
        <time class="project-date text-mono" datetime={date.toISOString()}>
          {formatDate(date)}
        </time>
      </div>

      <h1 class="project-title text-display">{title}</h1>

      {tags && tags.length > 0 && (
        <ul class="project-tags" aria-label="Project tags">
          {tags.map((tag) => (
            <li><span class="tag text-mono">{tag.toUpperCase()}</span></li>
          ))}
        </ul>
      )}
    </header>

    <div class="project-grid" style="--media-width: {mediaWidth}; --text-width: {textWidth};">
      <div class="project-media {mediaFirst ? 'media-first' : 'media-last'}">
        {model && (
          <div class="model-container">
            <ModelViewer
              src={model}
              alt={`${title} 3D model`}
              poster={modelPoster}
            />
          </div>
        )}

        {images && images.length > 0 && (
          <div class="image-gallery">
            {images.map((image, index) => (
              <figure class="gallery-item" data-index={index}>
                <img
                  src={image}
                  alt={`${title} - Image ${index + 1}`}
                  loading={index === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  width="800"
                  height="600"
                />
              </figure>
            ))}
          </div>
        )}

        {!model && (!images || images.length === 0) && (
          <div class="media-placeholder">
            <p class="text-soot">No media available</p>
          </div>
        )}
      </div>

      <div class="project-text {mediaFirst ? 'text-last' : 'text-first'}">
        <div class="project-description text-body">
          {description.split('\n\n').map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>

        {tools && tools.length > 0 && (
          <section class="project-tools">
            <h2 class="tools-title text-mono">TOOLS</h2>
            <ul class="tools-list">
              {tools.map((tool) => (
                <li><span class="tool text-mono">{tool}</span></li>
              ))}
            </ul>
          </section>
        )}

        {featured && (
          <div class="featured-badge text-mono">FEATURED PROJECT</div>
        )}
      </div>
    </div>
  </article>
  </main>
</ProjectLayout>

{images && images.length > 0 && (
  <MediaViewer images={images} title={title} />
)}

<style>
  .project-detail {
    padding: var(--space-2xl) var(--space-xl);
    padding-left: calc(var(--space-xl) * 2);
    padding-top: calc(var(--header-height) + var(--space-2xl));
  }

  .project-header {
    max-width: var(--max-width-prose);
    margin: 0 auto var(--space-3xl);
  }

  .back-link {
    display: inline-block;
    font-size: var(--type-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-soot);
    margin-bottom: var(--space-lg);
    transition: color var(--duration-fast) var(--ease-quick);
  }

  .back-link:hover {
    color: var(--color-oxide);
  }

  .project-meta {
    display: flex;
    gap: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .project-category,
  .project-date {
    font-size: var(--type-sm);
  }

  .project-title {
    font-size: var(--type-hero);
    font-weight: var(--font-weight-black);
    letter-spacing: var(--tracking-tight);
    line-height: var(--line-height-tighter);
    margin: 0 0 var(--space-lg);
    max-width: 60ch;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tag {
    font-size: var(--type-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-oxide-muted);
    background: var(--color-paper);
    padding: var(--space-2xs) var(--space-sm);
  }

  .project-grid {
    display: grid;
    grid-template-columns: var(--media-width) var(--text-width);
    gap: var(--space-3xl);
    max-width: var(--max-width-full);
    margin: 0 auto;
  }

  .media-first {
    grid-column: 1;
  }

  .media-last {
    grid-column: 2;
  }

  .text-first {
    grid-column: 1;
  }

  .text-last {
    grid-column: 2;
  }

  .project-media {
    position: sticky;
    top: calc(var(--header-height) + var(--space-xl));
    max-height: calc(100vh - var(--header-height) - var(--space-2xl));
    overflow-y: auto;
  }

  .model-container {
    aspect-ratio: 4 / 3;
    background: var(--color-paper);
    margin-bottom: var(--space-lg);
  }

  .model-container model-viewer {
    width: 100%;
    height: 100%;
  }

  .image-gallery {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .gallery-item {
    margin: 0;
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
  }

  .media-placeholder {
    aspect-ratio: 4 / 3;
    background: var(--color-paper);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-text {
    max-width: var(--max-width-prose);
  }

  .project-description {
    font-size: var(--type-base);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-2xl);
  }

  .project-description p {
    margin-bottom: var(--space-md);
    max-width: none;
  }

  .project-tools {
    margin-bottom: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-stone);
  }

  .tools-title {
    font-size: var(--type-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-oxide-muted);
    margin: 0 0 var(--space-md);
  }

  .tools-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tool {
    font-size: var(--type-sm);
    color: var(--color-soot);
    background: var(--color-paper);
    padding: var(--space-2xs) var(--space-sm);
  }

  .featured-badge {
    font-size: var(--type-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-oxide-muted);
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-oxide-muted);
    display: inline-block;
  }

  @media (max-width: 1024px) {
    .project-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .media-first,
    .media-last,
    .text-first,
    .text-last {
      grid-column: auto;
    }

    .project-media {
      position: static;
      max-height: none;
      overflow: visible;
    }

    .project-title {
      font-size: var(--type-2xl);
    }
  }

  @media (max-width: 768px) {
    .project-detail {
      padding: var(--space-xl) var(--space-md);
      padding-top: calc(var(--header-height) + var(--space-xl));
      padding-left: var(--space-md);
    }

    .project-meta {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .project-title {
      font-size: var(--type-xl);
    }
  }

  [data-theme="dark"] .tag,
  [data-theme="dark"] .tool {
    background: var(--color-paper);
  }
</style>